<!-- This file defines our physical world -->
<!-- This configuration cleanly separates the physics definition (the body/joint) from the measurement definition (the sensor). -->
<mujoco>
  <worldbody>
    <!-- 
        A floating box in the world with a free joint.
        Freejoint grants object 6 degrees of freedom (x,y,z,roll,pitch,yaw).
        3 translation, 3 rotation
    -->
    <body name="falling_box" pos="0 0 1">
      <!-- Added a name to the joint so we can search for them at runtime -->
      <freejoint name="box_joint"/>
      <geom type="box" size="0.1 0.1 0.1" rgba="0.8 0.2 0.2 1"/>
    </body>
  </worldbody>

  <!-- Dedicated sensor block -->
  <!-- Sensors measure properties of the system state (e.g., position, velocity, force). -->
  <sensor>
    <!-- framepos returns the global 3D position of an object's spatial frame -->
    <framepos name="box_position" objtype="body" objname="falling_box"/>
  </sensor>
</mujoco>